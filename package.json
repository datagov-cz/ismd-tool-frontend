{
  "name": "ismd-tool-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint:next": "next lint --fix",
    "lint": "eslint .",
    "eslint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "copy:icons": "copyfiles --flat ./node_modules/@gov-design-system-ce/icons/lib/components/* ./public/assets/icons/components && copyfiles --flat ./node_modules/@gov-design-system-ce/icons/lib/complex/* ./public/assets/icons/components",
    "copy:fonts": "copyfiles --flat ./node_modules/@gov-design-system-ce/fonts/lib/* ./src/fonts",
    "generate:api": "orval --config ./orval.config.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@gov-design-system-ce/react": "^2.4.2",
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.0.6",
    "@tailwindcss/postcss": "^4.1.17",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "next": "16.0.6",
    "next-auth": "^4.24.13",
    "next-intl": "^4.5.7",
    "postcss": "^8.5.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.67.0",
    "react-markdown": "^10.1.0",
    "react-toastify": "^11.0.5",
    "sugar-high": "^0.9.5",
    "tailwindcss": "^4.1.17",
    "zod": "^4.1.13",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.19.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "copyfiles": "^2.4.1",
    "eslint-config-next": "16.0.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "orval": "^7.17.0",
    "prettier": "^3.7.3",
    "typescript": "^5.9.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3"
  }
}
