{
  "name": "ismd-tool-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint:next": "next lint --fix",
    "lint": "eslint .",
    "eslint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "copy:icons": "copyfiles --flat ./node_modules/@gov-design-system-ce/icons/lib/components/* ./public/assets/icons/components && copyfiles --flat ./node_modules/@gov-design-system-ce/icons/lib/complex/* ./public/assets/icons/components",
    "copy:fonts": "copyfiles --flat ./node_modules/@gov-design-system-ce/fonts/lib/* ./src/fonts",
    "generate:api": "orval --config ./orval.config.cjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@gov-design-system-ce/react": "^2.4.2",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.5.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@tanstack/react-query": "^5.84.2",
    "axios": "^1.11.0",
    "next": "^14.2.32",
    "next-intl": "^4.3.4",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sugar-high": "^0.9.3",
    "tailwindcss": "^4.1.11",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.13",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.31",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "orval": "^7.11.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
